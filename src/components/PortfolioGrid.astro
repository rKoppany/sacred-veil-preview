---
import { readFileSync, readdirSync } from "node:fs";
import { extname, join } from "node:path";

const portfolioDirectory = join(process.cwd(), "public", "images", "portfolio-full");
const portfolioShuffleSeed = "sacred-veil-portfolio-order-2026-07-11";

const readJpegSize = (filePath: string) => {
  const buffer = readFileSync(filePath);
  let offset = 2;
  const startOfFrameMarkers = new Set([0xc0, 0xc1, 0xc2, 0xc3, 0xc5, 0xc6, 0xc7, 0xc9, 0xca, 0xcb, 0xcd, 0xce, 0xcf]);

  while (offset < buffer.length) {
    while (buffer[offset] === 0xff) offset += 1;
    const marker = buffer[offset];
    offset += 1;

    if (marker === 0xd9 || marker === 0xda) break;

    const length = buffer.readUInt16BE(offset);
    if (startOfFrameMarkers.has(marker)) {
      return {
        height: buffer.readUInt16BE(offset + 3),
        width: buffer.readUInt16BE(offset + 5)
      };
    }

    offset += length;
  }

  return { width: 1200, height: 800 };
};

const hashString = (value: string) => {
  let hash = 2166136261;
  for (let index = 0; index < value.length; index += 1) {
    hash ^= value.charCodeAt(index);
    hash = Math.imul(hash, 16777619);
  }
  return hash >>> 0;
};

const stableShuffle = <T extends { name: string }>(items: T[], seed: string) =>
  [...items].sort((a, b) => hashString(`${seed}-${a.name}`) - hashString(`${seed}-${b.name}`));

const buildMixedOrder = <T extends { orientation: "portrait" | "landscape" }>(items: T[]) => {
  const portraits = stableShuffle(
    items.filter((item) => item.orientation === "portrait"),
    `${portfolioShuffleSeed}-portrait`
  );
  const landscapes = stableShuffle(
    items.filter((item) => item.orientation === "landscape"),
    `${portfolioShuffleSeed}-landscape`
  );
  const ordered: T[] = [];
  let portraitIndex = 0;
  let landscapeIndex = 0;

  while (portraitIndex < portraits.length || landscapeIndex < landscapes.length) {
    const lastTwo = ordered.slice(-2).map((item) => item.orientation);
    const mustUsePortrait = lastTwo.length === 2 && lastTwo.every((orientation) => orientation === "landscape");
    const mustUseLandscape = lastTwo.length === 2 && lastTwo.every((orientation) => orientation === "portrait");
    const preferPortrait = ordered.length % 4 === 1 || ordered.length % 4 === 2;

    if ((mustUsePortrait || preferPortrait) && portraitIndex < portraits.length) {
      ordered.push(portraits[portraitIndex]);
      portraitIndex += 1;
    } else if ((mustUseLandscape || !preferPortrait) && landscapeIndex < landscapes.length) {
      ordered.push(landscapes[landscapeIndex]);
      landscapeIndex += 1;
    } else if (portraitIndex < portraits.length) {
      ordered.push(portraits[portraitIndex]);
      portraitIndex += 1;
    } else if (landscapeIndex < landscapes.length) {
      ordered.push(landscapes[landscapeIndex]);
      landscapeIndex += 1;
    }
  }

  return ordered;
};

const portfolioImages = buildMixedOrder(
  readdirSync(portfolioDirectory, { withFileTypes: true })
    .filter((entry) => entry.isFile())
    .filter((entry) => [".jpg", ".jpeg"].includes(extname(entry.name).toLowerCase()))
    .map((entry) => {
      const size = readJpegSize(join(portfolioDirectory, entry.name));
      return {
        ...size,
        aspect: size.width / size.height,
        name: entry.name,
        orientation: size.width >= size.height ? "landscape" : "portrait" as "portrait" | "landscape",
        src: `images/portfolio-full/${encodeURIComponent(entry.name)}`
      };
    })
);
---

<section class="section portfolio-section pt-0">
  <div class="portfolio-shell">
    <div class="portfolio-wall" data-gallery data-portfolio-masonry>
      {portfolioImages.map((image, index) => (
        <button
          class="portfolio-card"
          type="button"
          data-aspect={image.aspect}
          data-lightbox={image.src}
          data-orientation={image.orientation}
          aria-label={`Sacred Veil portfóliófotó ${index + 1} megnyitása`}
        >
          <img
            src={image.src}
            alt={`Sacred Veil portfóliófotó ${index + 1}`}
            width={image.width}
            height={image.height}
            loading={index < 18 ? "eager" : "lazy"}
            fetchpriority={index < 8 ? "high" : "auto"}
            decoding="async"
            data-portfolio-image
          />
        </button>
      ))}
    </div>
  </div>
</section>

<div class="fixed inset-0 z-[70] hidden bg-white/[0.86] backdrop-blur-sm" data-lightbox-modal aria-hidden="true">
  <button class="lightbox-control lightbox-control-close lightbox-close-position" type="button" data-lightbox-close aria-label="Nagyított kép bezárása">
    <svg viewBox="0 0 392 385" aria-hidden="true">
      <path class="lightbox-x-outline" d="M66 44L326 301M326 44L66 301"></path>
      <path class="lightbox-x-core" d="M66 44L326 301M326 44L66 301"></path>
    </svg>
  </button>

  <div class="lightbox-stage">
    <img src="" alt="Nagyított portfóliófotó" data-lightbox-image />
  </div>

  <div class="lightbox-arrows-position flex items-center justify-center gap-10">
    <button class="lightbox-control lightbox-control-prev" type="button" data-lightbox-prev aria-label="Előző kép">
      <svg viewBox="0 0 216 165" aria-hidden="true">
        <g transform="translate(216 0) scale(-1 1)">
          <path class="lightbox-arrow-outline" d="M17 86H197M146 27L197 86L146 141"></path>
          <path class="lightbox-arrow-core" d="M17 86H197M146 27L197 86L146 141"></path>
        </g>
      </svg>
    </button>
    <button class="lightbox-control lightbox-control-next" type="button" data-lightbox-next aria-label="Következő kép">
      <svg viewBox="0 0 216 165" aria-hidden="true">
        <path class="lightbox-arrow-outline" d="M17 86H197M146 27L197 86L146 141"></path>
        <path class="lightbox-arrow-core" d="M17 86H197M146 27L197 86L146 141"></path>
      </svg>
    </button>
  </div>
</div>

<script>
  const modal = document.querySelector("[data-lightbox-modal]");
  const modalImage = document.querySelector("[data-lightbox-image]");
  const lightboxStage = document.querySelector(".lightbox-stage");
  const closeButton = document.querySelector("[data-lightbox-close]");
  const previousButton = document.querySelector("[data-lightbox-prev]");
  const nextButton = document.querySelector("[data-lightbox-next]");
  const galleryButtons = Array.from(document.querySelectorAll("[data-lightbox]"));
  let currentIndex = 0;
  let isLightboxAnimating = false;
  let lastScrollY = window.scrollY;

  const waitForImage = (image) => {
    if (!(image instanceof HTMLImageElement)) return Promise.resolve();
    if (image.complete && image.naturalWidth > 0) return Promise.resolve();
    return new Promise((resolve) => {
      image.addEventListener("load", resolve, { once: true });
      image.addEventListener("error", resolve, { once: true });
    });
  };

  const animateImageFromRect = async (fromRect, duration = 600) => {
    if (!(modalImage instanceof HTMLImageElement) || prefersReducedMotion) return;
    await waitForImage(modalImage);
    const targetRect = modalImage.getBoundingClientRect();
    const scaleX = fromRect.width / targetRect.width;
    const scaleY = fromRect.height / targetRect.height;
    const translateX = fromRect.left - targetRect.left;
    const translateY = fromRect.top - targetRect.top;

    modalImage.style.transformOrigin = "top left";
    await modalImage.animate(
      [
        { opacity: 0.72, transform: `translate3d(${translateX}px, ${translateY}px, 0) scale(${scaleX}, ${scaleY})` },
        { opacity: 1, transform: "translate3d(0, 0, 0) scale(1, 1)" }
      ],
      { duration, easing: "cubic-bezier(0.16, 0.84, 0.22, 1)" }
    ).finished;
    modalImage.style.transformOrigin = "";
  };

  const animateImageToRect = async (toRect, duration = 600) => {
    if (!(modalImage instanceof HTMLImageElement) || prefersReducedMotion) return;
    const currentRect = modalImage.getBoundingClientRect();
    const scaleX = toRect.width / currentRect.width;
    const scaleY = toRect.height / currentRect.height;
    const translateX = toRect.left - currentRect.left;
    const translateY = toRect.top - currentRect.top;

    modalImage.style.transformOrigin = "top left";
    await modalImage.animate(
      [
        { opacity: 1, transform: "translate3d(0, 0, 0) scale(1, 1)" },
        { opacity: 0.72, transform: `translate3d(${translateX}px, ${translateY}px, 0) scale(${scaleX}, ${scaleY})` }
      ],
      { duration, easing: "cubic-bezier(0.16, 0.84, 0.22, 1)" }
    ).finished;
    modalImage.style.transformOrigin = "";
  };

  const showImage = (index) => {
    if (!(modalImage instanceof HTMLImageElement) || galleryButtons.length === 0) return;
    currentIndex = (index + galleryButtons.length) % galleryButtons.length;
    modalImage.src = galleryButtons[currentIndex].getAttribute("data-lightbox") || "";
  };

  galleryButtons.forEach((button, index) => {
    button.addEventListener("click", async () => {
      if (isLightboxAnimating) return;
      isLightboxAnimating = true;
      const sourceRect = button.getBoundingClientRect();
      showImage(index);
      modal?.classList.remove("hidden");
      modal?.classList.add("block");
      modal?.classList.remove("is-closing");
      modal?.setAttribute("aria-hidden", "false");
      document.documentElement.style.overflow = "hidden";
      window.requestAnimationFrame(() => modal?.classList.add("is-open"));
      await animateImageFromRect(sourceRect, 600);
      isLightboxAnimating = false;
    });
  });

  const close = async () => {
    if (isLightboxAnimating) return;
    isLightboxAnimating = true;
    const targetButton = galleryButtons[currentIndex];
    const targetRect = targetButton?.getBoundingClientRect();
    const targetIsVisible = Boolean(
      targetRect &&
        targetRect.width > 0 &&
        targetRect.height > 0 &&
        targetRect.bottom > 0 &&
        targetRect.right > 0 &&
        targetRect.top < window.innerHeight &&
        targetRect.left < window.innerWidth
    );

    modal?.classList.remove("is-open");
    modal?.classList.add("is-closing");

    if (targetIsVisible && targetRect) {
      await Promise.all([
        animateImageToRect(targetRect, 600),
        new Promise((resolve) => window.setTimeout(resolve, 500))
      ]);
    } else if (modalImage instanceof HTMLImageElement && !prefersReducedMotion) {
      await Promise.all([
        modalImage.animate([{ opacity: 1 }, { opacity: 0 }], { duration: 500, easing: "ease" }).finished,
        new Promise((resolve) => window.setTimeout(resolve, 500))
      ]);
    } else {
      await new Promise((resolve) => window.setTimeout(resolve, 1));
    }

    modal?.classList.add("hidden");
    modal?.classList.remove("block");
    modal?.classList.remove("is-closing");
    modal?.setAttribute("aria-hidden", "true");
    document.documentElement.style.overflow = "";
    if (modalImage instanceof HTMLImageElement) {
      modalImage.style.opacity = "";
      modalImage.style.transform = "";
    }
    isLightboxAnimating = false;
  };

  closeButton?.addEventListener("click", close);
  const slideLightboxImage = async (direction) => {
    if (!(modalImage instanceof HTMLImageElement) || !(lightboxStage instanceof HTMLElement) || isLightboxAnimating) return;
    if (prefersReducedMotion) {
      showImage(currentIndex + direction);
      return;
    }

    isLightboxAnimating = true;
    const oldRect = modalImage.getBoundingClientRect();
    const ghost = document.createElement("img");
    ghost.className = "lightbox-image-ghost";
    ghost.src = modalImage.src;
    ghost.alt = "";
    ghost.style.left = `${oldRect.left}px`;
    ghost.style.borderRadius = "8px";
    ghost.style.boxShadow = "0 24px 80px rgba(74, 57, 49, 0.18)";
    ghost.style.height = `${oldRect.height}px`;
    ghost.style.objectFit = "contain";
    ghost.style.pointerEvents = "none";
    ghost.style.position = "fixed";
    ghost.style.top = `${oldRect.top}px`;
    ghost.style.width = `${oldRect.width}px`;
    ghost.style.zIndex = "1";
    modal?.appendChild(ghost);

    showImage(currentIndex + direction);
    modalImage.style.opacity = "0";
    await waitForImage(modalImage);

    const newRect = modalImage.getBoundingClientRect();
    const oldDistance = oldRect.width * (direction > 0 ? -1 : 1);
    const newDistance = newRect.width * (direction > 0 ? 1 : -1);
    const newAnimation = modalImage.animate(
      [
        { opacity: 0, transform: `translate3d(${newDistance}px, 0, 0)` },
        { opacity: 1, transform: "translate3d(0, 0, 0)" }
      ],
      { duration: 800, easing: "linear", fill: "forwards" }
    ).finished;

    const oldAnimation = new Promise((resolve) => {
      window.setTimeout(() => {
        ghost.animate(
          [
            { opacity: 1, transform: "translate3d(0, 0, 0)" },
            { opacity: 0, transform: `translate3d(${oldDistance}px, 0, 0)` }
          ],
          { duration: 800, easing: "linear", fill: "forwards" }
        ).finished.then(resolve);
      }, 400);
    });

    await Promise.all([oldAnimation, newAnimation]);
    ghost.remove();
    modalImage.style.opacity = "";
    modalImage.style.transform = "";
    isLightboxAnimating = false;
  };

  previousButton?.addEventListener("click", () => slideLightboxImage(-1));
  nextButton?.addEventListener("click", () => slideLightboxImage(1));
  modal?.addEventListener("click", (event) => {
    if (event.target === modal) close();
  });
  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") close();
    if (event.key === "ArrowLeft") slideLightboxImage(-1);
    if (event.key === "ArrowRight") slideLightboxImage(1);
  });

  const masonryWall = document.querySelector("[data-portfolio-masonry]");
  const portfolioCards = Array.from(document.querySelectorAll(".portfolio-card"));
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const widthRatioByCount = { 1: 0.9, 2: 0.4, 3: 0.25, 4: 0.2 };
  let layoutFrame = 0;

  const getColumnCount = () => {
    const width = window.innerWidth;
    const height = window.innerHeight;
    const isLandscape = width > height;
    const shortSide = Math.min(width, height);

    if (shortSide < 600) return isLandscape ? 2 : 1;
    if (width < 1024) return isLandscape ? 3 : 2;
    return isLandscape ? 4 : 3;
  };

  const primeImage = (image) => {
    if (!(image instanceof HTMLImageElement)) return;
    image.loading = "eager";
  };

  const revealCard = (card) => {
    if (!(card instanceof HTMLElement)) return;
    const image = card.querySelector("[data-portfolio-image]");
    primeImage(image);
    card.classList.add("is-visible");
  };

  const hideCard = (card) => {
    if (!(card instanceof HTMLElement)) return;
    card.classList.remove("is-visible");
  };

  const revealCards = () => {
    const viewportBottom = window.innerHeight;
    const preloadTop = -window.innerHeight * 0.65;
    const preloadBottom = window.innerHeight * 2.6;
    const isScrollingUp = window.scrollY < lastScrollY;
    portfolioCards.forEach((card) => {
      const rect = card.getBoundingClientRect();
      const image = card instanceof HTMLElement ? card.querySelector("[data-portfolio-image]") : null;

      if (rect.top <= preloadBottom && rect.bottom >= preloadTop) {
        primeImage(image);
      }

      if (rect.top + rect.height / 2 <= viewportBottom) {
        revealCard(card);
      } else if (isScrollingUp) {
        hideCard(card);
      }
    });
    lastScrollY = window.scrollY;
  };

  const layoutMasonry = () => {
    layoutFrame = 0;
    if (!(masonryWall instanceof HTMLElement)) return;

    const columns = getColumnCount();
    const computedStyle = window.getComputedStyle(masonryWall);
    const gap = parseFloat(computedStyle.getPropertyValue("--portfolio-gap")) || 18;
    const targetWidth = window.innerWidth * widthRatioByCount[columns];
    const availableWidth = masonryWall.clientWidth;
    const itemWidth = Math.floor(Math.min(targetWidth, (availableWidth - gap * (columns - 1)) / columns));
    const totalWidth = itemWidth * columns + gap * (columns - 1);
    const startX = Math.max((availableWidth - totalWidth) / 2, 0);
    const columnHeights = Array.from({ length: columns }, () => 0);

    masonryWall.classList.add("is-enhanced");
    masonryWall.dataset.columns = String(columns);

    portfolioCards.forEach((card) => {
      if (!(card instanceof HTMLElement)) return;
      const aspect = Number(card.dataset.aspect) || 1.5;
      const columnIndex = columnHeights.indexOf(Math.min(...columnHeights));
      const x = startX + columnIndex * (itemWidth + gap);
      const y = columnHeights[columnIndex];
      const height = itemWidth / aspect;

      card.style.width = `${itemWidth}px`;
      card.style.height = `${height}px`;
      card.style.setProperty("--portfolio-x", `${x}px`);
      card.style.setProperty("--portfolio-y", `${y}px`);
      columnHeights[columnIndex] += height + gap;
    });

    masonryWall.style.height = `${Math.max(...columnHeights) - gap}px`;
    revealCards();
  };

  const queueLayout = () => {
    if (layoutFrame) return;
    layoutFrame = window.requestAnimationFrame(layoutMasonry);
  };

  const queueReveal = () => {
    window.requestAnimationFrame(revealCards);
  };

  if (masonryWall && portfolioCards.length > 0) {
    layoutMasonry();
    window.addEventListener("resize", queueLayout);
    window.addEventListener("orientationchange", queueLayout);
    window.addEventListener("scroll", queueReveal, { passive: true });
    window.addEventListener("load", queueLayout, { once: true });

    if (prefersReducedMotion) {
      portfolioCards.forEach((card) => {
        if (card instanceof HTMLElement) {
          primeImage(card.querySelector("[data-portfolio-image]"));
          card.classList.add("is-visible");
        }
      });
    }
  }
</script>

<style>
  .portfolio-section {
    padding-inline: clamp(0.75rem, 2vw, 1.5rem);
  }

  .portfolio-shell {
    margin-inline: auto;
    width: min(1920px, 100%);
  }

  .portfolio-wall {
    --portfolio-gap: clamp(0.7rem, 1.15vw, 1.25rem);
    align-items: flex-start;
    display: flex;
    flex-wrap: wrap;
    gap: var(--portfolio-gap);
    justify-content: center;
    margin-inline: auto;
    position: relative;
  }

  .portfolio-card {
    background: var(--veil);
    border: 0;
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(74, 57, 49, 0.12);
    cursor: pointer;
    display: block;
    flex: 0 0 min(90vw, 420px);
    overflow: hidden;
    padding: 0;
    text-align: left;
    transition: box-shadow 220ms ease;
  }

  .portfolio-card img {
    display: block;
    height: 100%;
    object-fit: contain;
    opacity: 1;
    transition: transform 260ms ease;
    width: 100%;
  }

  .portfolio-card:hover {
    box-shadow: 0 30px 90px rgba(74, 57, 49, 0.18);
  }

  .portfolio-card:hover img {
    transform: scale(1.03);
  }

  .portfolio-wall.is-enhanced {
    display: block;
  }

  .portfolio-wall.is-enhanced .portfolio-card {
    left: 0;
    opacity: 1;
    position: absolute;
    top: 0;
    transform: translate3d(var(--portfolio-x, 0), var(--portfolio-y, 0), 0);
    transition:
      transform 1200ms cubic-bezier(0.16, 0.84, 0.22, 1),
      box-shadow 220ms ease;
    will-change: transform;
  }

  .portfolio-wall.is-enhanced .portfolio-card:not(.is-visible) {
    transform: translate3d(var(--portfolio-x, 0), calc(var(--portfolio-y, 0) + 36px), 0);
  }

  .portfolio-wall.is-enhanced .portfolio-card.is-visible {
    transform: translate3d(var(--portfolio-x, 0), var(--portfolio-y, 0), 0);
  }

  [data-lightbox-modal] {
    opacity: 0;
    transition: opacity 500ms ease;
  }

  [data-lightbox-modal].is-open {
    opacity: 1;
  }

  [data-lightbox-modal].is-closing {
    opacity: 0;
  }

  [data-lightbox-image] {
    will-change: opacity, transform;
  }

  [data-lightbox-modal] .lightbox-control,
  [data-lightbox-modal] .lightbox-arrows-position {
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 500ms ease, transform 500ms cubic-bezier(0.16, 0.84, 0.22, 1);
  }

  [data-lightbox-modal].is-open .lightbox-control,
  [data-lightbox-modal].is-open .lightbox-arrows-position {
    opacity: 1;
    transform: translateY(0);
  }

  .lightbox-image-ghost {
    border-radius: 8px;
    box-shadow: 0 24px 80px rgba(74, 57, 49, 0.18);
    object-fit: contain;
    pointer-events: none;
    position: fixed;
    z-index: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-wall.is-enhanced .portfolio-card,
    .portfolio-wall.is-enhanced .portfolio-card.is-visible,
    .portfolio-card:hover img,
    [data-lightbox-modal],
    [data-lightbox-modal] .lightbox-control,
    [data-lightbox-modal] .lightbox-arrows-position {
      opacity: 1;
      transform: translate3d(var(--portfolio-x, 0), var(--portfolio-y, 0), 0);
      transition: none;
    }
  }
</style>
