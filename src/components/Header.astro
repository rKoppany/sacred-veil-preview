---
import { navItems } from "../data/site";
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-white/30 bg-ivory/86 backdrop-blur-xl">
  <a class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[60] focus:bg-white focus:px-4 focus:py-2" href="#main">Ugrás a tartalomra</a>
  <div class="site-header-inner mx-auto flex h-20 w-full max-w-7xl items-center justify-between px-5">
    <a href="index.html" class="site-brand flex items-center gap-3 font-display text-3xl font-semibold text-ink" aria-label="Sacred Veil főoldal">
      <span class="brand-mark h-11 w-11">
        <img src="images/brand/sacred-veil-logo-transparent.png?v=20260722" alt="" loading="eager" />
      </span>
      <span class="site-brand-name">Sacred Veil</span>
    </a>
    <nav class="site-nav hidden items-center gap-8 text-sm font-semibold text-taupe lg:flex" aria-label="Fő navigáció">
      {navItems.map((item) => <a class="transition hover:text-rosegold" href={item.href}>{item.label}</a>)}
    </nav>
    <a class="site-nav-cta button button-primary hidden lg:inline-flex" href="kapcsolat.html">Árajánlatot kérek</a>
    <button class="button button-secondary lg:hidden" type="button" data-menu-button aria-expanded="false" aria-controls="mobile-menu">
      Menü
    </button>
  </div>
  <nav id="mobile-menu" class="hidden border-t border-taupe/10 bg-ivory px-5 py-6 lg:hidden" aria-label="Mobil navigáció" data-mobile-menu>
    <div class="flex flex-col gap-4">
      {navItems.map((item) => <a class="py-2 text-lg font-semibold" href={item.href}>{item.label}</a>)}
      <a class="button button-primary mt-2" href="kapcsolat.html">Árajánlatot kérek</a>
    </div>
  </nav>
</header>
