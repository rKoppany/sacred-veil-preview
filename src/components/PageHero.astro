---
interface Props {
  eyebrow: string;
  title: string;
  lead: string;
  image?: string;
  class?: string;
  imageClass?: string;
}

const { eyebrow, title, lead, image, class: className = "", imageClass = "" } = Astro.props;
---

<section class={`section pt-32 page-hero ${className}`}>
  <div class="container grid items-center gap-10 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="reveal">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="page-title mt-4">{title}</h1>
      <p class="mt-6 max-w-2xl text-lg text-taupe/78">{lead}</p>
    </div>
    {image && (
      <div class={`media-frame aspect-[4/3] reveal ${imageClass}`}>
        <img src={image} alt="" loading="eager" />
      </div>
    )}
  </div>
</section>
