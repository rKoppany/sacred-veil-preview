---
import Layout from "../components/Layout.astro";
import PageHero from "../components/PageHero.astro";
import PortfolioGrid from "../components/PortfolioGrid.astro";
---

<Layout title="Portfólió | Sacred Veil" description="Sacred Veil esküvői, polgári és jegyesfotózás portfólió válogatás valódi fotókkal.">
  <PageHero eyebrow="Portfólió" title="Sacred Signature Collection" image="images/portfolio/portfolio-03.webp" />
  <PortfolioGrid />
  <section class="section bg-veil">
    <div class="container text-center">
      <p class="eyebrow">Tetszik a hangulat?</p>
      <h2 class="section-title mx-auto mt-4 max-w-3xl">Kérjetek személyre szabott ajánlatot, és megnézzük, hogyan illeszkedik ez a képi világ a ti napotokhoz.</h2>
      <a class="button button-primary mt-8" href="kapcsolat.html">Árajánlatot kérek</a>
    </div>
  </section>
</Layout>
